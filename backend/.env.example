# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/library_db

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=http://localhost:3000

# Fine calculation (currency units per day overdue)
FINE_PER_DAY=5
LOAN_PERIOD_DAYS=14
